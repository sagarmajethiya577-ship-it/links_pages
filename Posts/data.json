  "post": {
    "content": "\n<div class=\"post-wrap\">\n<div class=\"top-note\">\n<h1>👇 Always Use 👇</h1>\n<h1><a href=\"https://moviezone-22y.pages.dev/\">Movies Zone 🍿</a></h1>\n</div>\n<div id=\"content\"></div>\n</div>\n<script>\n// URL se 'name' parameter nikalna (Pretty URL safe)\nconst params = new URLSearchParams(window.location.search);\nlet slug = params.get(\"name\");\nif (slug) slug = slug.replace(\".html\", \"\");\n\n// Dynamic JSON fetch karna\nfetch(\"data.json\")\n.then(res => res.json())\n.then(data => {\n    if(slug && data[slug]) {\n        document.getElementById(\"content\").innerHTML = data[slug].content;\n    } else {\n        document.getElementById(\"content\").innerHTML = \"<h1 style='text-align:center'>❌ Post Not Found</h1>\";\n    }\n})\n.catch(err => {\n    console.error(\"Error loading JSON:\", err);\n    document.getElementById(\"content\").innerHTML = \"<h1 style='text-align:center'>❌ Data Load Error</h1>\";\n});\n\n// Back button redirect (1st time only)\nlet redirected = false;\nhistory.pushState(null, null, location.href);\nwindow.onpopstate = function () {\n    if (!redirected) {\n        redirected = true;\n        window.location.href = \"https://omg10.com/4/7719049\";\n    } else {\n        history.back();\n    }\n};\n</script>\n"
  },
